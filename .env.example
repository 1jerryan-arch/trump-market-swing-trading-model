# Trump Market Swing Trading Model — Environment Configuration
# Copy this file to .env and fill in your actual values.
# The .env file is gitignored and will NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # Then edit .env with your real API key
#
# Or export directly in shell:
#   export XAI_API_KEY=your-key-here

# =========================================================
# REQUIRED: xAI Grok API Key
# Get yours at: https://console.x.ai/
# Used for: Component 3 Stage 2 — Grok API Tweet Analyzer
# =========================================================
XAI_API_KEY=your-xai-api-key-here

# =========================================================
# OPTIONAL: Cost & Rate Limit Overrides
# (Defaults are set in code — only override if needed)
# =========================================================

# Daily API call hard cap (default: 500)
# GROK_DAILY_CALL_LIMIT=500

# Circuit breaker — max daily spend in USD (default: 0.30)
# GROK_DAILY_SPEND_LIMIT=0.30

# Market-moving signal probability threshold (default: 0.60)
# GROK_MM_THRESHOLD=0.60

# =========================================================
# OPTIONAL: Portfolio Configuration
# =========================================================

# Starting portfolio value in USD (default: 100000)
# PORTFOLIO_VALUE=100000

# Portfolio state persistence file path (default: content/portfolio_state.json)
# PORTFOLIO_STATE_FILE=content/portfolio_state.json
